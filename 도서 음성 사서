col_rec, col_update = st.columns([3, 1])
with col_rec:
    rec_duration = st.selectbox(
        "녹음 시간", [3, 5, 7, 10], index=1, label_visibility="collapsed"
    )
with col_update:
    if st.button("🔄 인기도서 갱신", use_container_width=True):
        with st.spinner("인기도서 데이터 갱신 중..."):
            run_books_update()
        st.success("인기도서 갱신 완료!")

# --- 음성 입력 ---
if st.button("🎤 음성으로 질문하기", use_container_width=True):
    update_activity()
    with st.spinner(f"🎙️ {rec_duration}초 동안 녹음 중..."):
        user_text = record_and_transcribe(rec_duration)

    if user_text.strip():
        st.session_state.messages.append({"role": "user", "content": f"🎤 {user_text}"})
        with st.chat_message("user"):
            st.markdown(f"🎤 {user_text}")

        with st.spinner("🤖 AI가 분석 중..."):
            df, answer, sql = ask_gemini(user_text)

        with st.chat_message("assistant"):
            st.markdown(answer)
            if df is not None and not df.empty:
                st.dataframe(df, use_container_width=True)
            if sql:
                with st.expander("🔍 실행된 SQL"):
                    st.code(sql, language="sql")

        st.session_state.messages.append({
            "role": "assistant", "content": answer,
            "dataframe": df if df is not None and not df.empty else None,
        })

        audio_path = speak(answer)
        st.audio(audio_path, autoplay=True)
    else:
        st.warning("🔇 음성이 감지되지 않았습니다. 마이크를 확인하거나 다시 시도해 주세요.")

# --- 텍스트 입력 ---
if user_input := st.chat_input("💬 텍스트로 질문하세요 (예: 20대 여성 인기도서 추천해줘)"):
    update_activity()
    st.session_state.messages.append({"role": "user", "content": user_input})
    with st.chat_message("user"):
        st.markdown(user_input)

    with st.spinner("🤖 AI가 분석 중..."):
        df, answer, sql = ask_gemini(user_input)

    with st.chat_message("assistant"):
        st.markdown(answer)
        if df is not None and not df.empty:
            st.dataframe(df, use_container_width=True)
        if sql:
            with st.expander("🔍 실행된 SQL"):
                st.code(sql, language="sql")

    st.session_state.messages.append({
        "role": "assistant", "content": answer,
        "dataframe": df if df is not None and not df.empty else None,
    })

    audio_path = speak(answer)
    st.audio(audio_path, autoplay=True)


def parse_gemini_response(raw_text: str) -> dict:
    """Gemini 응답에서 JSON 추출 (코드블록 제거 포함)"""
    cleaned = raw_text.strip()
    cleaned = re.sub(r"```json\s*", "", cleaned)
    cleaned = re.sub(r"```\s*", "", cleaned)
    return json.loads(cleaned)


def validate_sql(sql: str) -> bool:
    """SQL 안전성 검증: SELECT만 허용"""
    if not sql or not sql.strip():
        return False
    forbidden = ["INSERT", "UPDATE", "DELETE", "DROP", "ALTER", "CREATE", "TRUNCATE", "GRANT"]
    upper = sql.upper().strip()
    if not upper.startswith("SELECT"):
        return False
    for kw in forbidden:
        if kw in upper:
            return False
    return True


def ask_gemini(user_text: str):
    """
    사용자 질문 → Gemini → SQL 실행 → (DataFrame, 안내 메시지, SQL문)
    이전 대화 맥락을 포함하여 "그것들", "접수기간도 보여줘" 등의 후속 질문 지원
    """
    try:
        # 이전 대화 기록 구성 (최근 6개까지)
        history = ""
        recent_msgs = st.session_state.messages[-6:] if st.session_state.messages else []
        if recent_msgs:
            history = "\n## 이전 대화 기록\n"
            for msg in recent_msgs:
                role = "사용자" if msg["role"] == "user" else "AI사서"
                history += f"- {role}: {msg['content'][:200]}\n"

        # 1) Gemini 호출 (질의용 키 + 대화 맥락)
        full_prompt = f"{SYSTEM_PROMPT}\n{history}\n사용자 질문: \"{user_text}\""
        response = gemini_query.generate_content(full_prompt)
        result = parse_gemini_response(response.text)

        intent = result.get("intent", "unknown")
        sql = result.get("sql", "")
        message = result.get("message", "")

        # 2) unknown이면 SQL 없이 안내만
        if intent == "unknown" or not sql:
            return None, message or "죄송합니다. 질문을 이해하지 못했어요. 다시 말씀해 주시겠어요?", ""

        # 3) SQL 안전성 검증
        if not validate_sql(sql):
            return None, "안전하지 않은 쿼리가 감지되었습니다.", sql

        # 4) SQL 실행 (LIKE의 % 문자 이스케이프 처리)
        safe_sql = sql.replace("%", "%%")
        with engine.connect() as conn:
            result = conn.execute(text(safe_sql))
            df = pd.DataFrame(result.fetchall(), columns=result.keys())

        # 5) 결과가 없을 때
        if df.empty:
            return df, "검색 결과가 없습니다. 다른 조건으로 다시 질문해 주세요.", sql

        # 6) 기능별 맞춤 메시지 보강
        if intent == "location" and "class_no" in df.columns:
            row = df.iloc[0]
            class_name = row.get("class_nm", "")
            class_no = row.get("class_no", "")
            book_name = row.get("title", "")
            message = (
                f"'{book_name}'은(는) {class_name} 분야 도서입니다. "
                f"분류번호 {class_no}번 서가에서 찾으실 수 있습니다."
            )

        if intent == "recommend" and len(df) > 0:
            top = df.iloc[0]
            message += f" 1위는 '{top.get('BookName', '')}'입니다."

        return df, message, sql

    except json.JSONDecodeError:
        return None, "AI 응답을 처리하는 중 오류가 발생했습니다. 다시 시도해 주세요.", ""
    except Exception as e:
        return None, f"처리 중 오류가 발생했습니다: {str(e)}", ""



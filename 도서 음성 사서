def _create_detail_driver():
    """상세 페이지 크롤링용 별도 Chrome 세션 생성"""
    chrome_opts = Options()
    chrome_opts.add_argument("--headless")
    chrome_opts.add_argument("--no-sandbox")
    chrome_opts.add_argument("--disable-dev-shm-usage")
    chrome_opts.add_argument("--window-size=1920,1080")
    return webdriver.Chrome(options=chrome_opts)


def _gemini_call_with_retry(content, max_retries=5):
    """Gemini API 호출 (크롤링용 키) + 429 에러 시 대기 후 재시도"""
    for attempt in range(max_retries):
        try:
            genai.configure(api_key=GEMINI_KEY_CRAWL)
            model = genai.GenerativeModel(GEMINI_MODEL)
            result = model.generate_content(content)
            _restore_query_model()
            return result
        except Exception as e:
            error_str = str(e)
            if "429" in error_str:
                wait_sec = 65 * (attempt + 1)
                print(f"    ⏳ API 할당량 초과, {wait_sec}초 대기 후 재시도... ({attempt + 1}/{max_retries})")
                time.sleep(wait_sec)
            else:
                _restore_query_model()
                raise e
    _restore_query_model()
    raise Exception("Gemini API 재시도 횟수 초과")


def _extract_detail_with_gemini(detail_url):
    """
    게시물 상세 페이지에서 정보를 추출한다.
    별도 Chrome 세션을 열어서 메인 목록 크롤러와 충돌하지 않게 한다.

    전략:
    1) 별도 headless Chrome으로 상세 페이지 접근
    2) 텍스트 충분 → Gemini 텍스트 모드
    3) 텍스트 부족 (이미지만) → 이미지 다운로드 or 스크린샷 → Gemini Vision
    """
    import base64

    empty_result = {"운영기간": "", "운영대상": "", "접수기간": ""}

    extraction_prompt_template = """
아래는 마포평생학습관 강연/프로그램 게시물의 내용이야.
여기서 다음 3가지 정보를 추출해줘:

1. **운영기간** (= 강의기간, 수강기간, 교육기간, 운영일시, 강좌기간, 일시 등)
2. **운영대상** (= 대상, 모집대상, 수강대상, 참여대상 등)  
3. **접수기간** (= 모집기간, 신청기간, 접수일시, 등록기간 등)

규칙:
- 해당 정보가 없으면 빈 문자열로 남겨
- 날짜는 원문 그대로 유지
- 반드시 아래 JSON 형식만 출력 (다른 텍스트 금지)

```json
{{"운영기간": "추출된 값", "운영대상": "추출된 값", "접수기간": "추출된 값"}}
```
"""

    detail_driver = None
    try:
        # 별도 Chrome 세션
        detail_driver = _create_detail_driver()
        detail_driver.get(detail_url)
        time.sleep(2)

        # --- 이미지 수집 (텍스트/Vision 모두에서 사용 가능) ---
        import base64
        image_parts = []
        for selector in [".contentArea img", "#contentcore img",
                         ".board-view img", ".bbs_detail img", "#contents img"]:
            try:
                imgs = detail_driver.find_elements(By.CSS_SELECTOR, selector)
                for img in imgs[:5]:
                    src = img.get_attribute("src")
                    if src and not src.endswith((".gif", ".ico")):
                        img_resp = requests.get(src, timeout=10)
                        if img_resp.status_code == 200 and len(img_resp.content) > 5000:
                            img_b64 = base64.b64encode(img_resp.content).decode("utf-8")
                            ct = img_resp.headers.get("Content-Type", "image/png")
                            mime = "image/jpeg" if ("jpeg" in ct or "jpg" in ct) else "image/png"
                            image_parts.append({
                                "inline_data": {"mime_type": mime, "data": img_b64}
                            })
                if image_parts:
                    break
            except Exception:
                continue

        # 이미지 태그 없으면 스크린샷
        if not image_parts:
            screenshot = detail_driver.get_screenshot_as_png()
            img_b64 = base64.b64encode(screenshot).decode("utf-8")
            image_parts.append({
                "inline_data": {"mime_type": "image/png", "data": img_b64}
            })

        # --- 본문 텍스트 수집 ---
        body_text = ""
        for selector in [".contentArea", "#contentcore", ".board-view",
                         ".bbs_detail", ".view_cont", "#contents"]:
            try:
                el = detail_driver.find_element(By.CSS_SELECTOR, selector)
                body_text = el.text.strip()
                if len(body_text) > 50:
                    break
            except Exception:
                continue

        # --- 1차: 텍스트 모드 시도 ---
        parsed = None
        if body_text and len(body_text) > 50:
            prompt = extraction_prompt_template + f"\n본문:\n{body_text[:3000]}"
            response = _gemini_call_with_retry(prompt)
            raw = response.text.strip()
            raw = re.sub(r"```json\s*", "", raw)
            raw = re.sub(r"```\s*", "", raw)
            try:
                parsed = json.loads(raw)
            except json.JSONDecodeError:
                parsed = None

        # --- 텍스트 결과가 비어있으면 Vision 폴백 ---
        if not parsed or (not parsed.get("운영기간") and not parsed.get("운영대상") and not parsed.get("접수기간")):
            if parsed:
                print(f"    → 텍스트 모드에서 정보 없음, Vision 모드로 재시도")
            else:
                print(f"    → Vision 모드 사용")

            content_parts = image_parts + [
                {"text": extraction_prompt_template + "\n위 이미지에서 정보를 추출해줘."}
            ]
            response = _gemini_call_with_retry(content_parts)
            raw = response.text.strip()
            raw = re.sub(r"```json\s*", "", raw)
            raw = re.sub(r"```\s*", "", raw)
            parsed = json.loads(raw)

        return {
            "운영기간": parsed.get("운영기간", ""),
            "운영대상": parsed.get("운영대상", ""),
            "접수기간": parsed.get("접수기간", ""),
        }

    except Exception as e:
        print(f"    [상세] 추출 실패: {e}")
        return empty_result
    finally:
        if detail_driver:
            try:
                detail_driver.quit()
            except Exception:
                pass


def update_everlearning():
    """기능 2: 에버러닝 마포 크롤링 → 목록 + 상세(운영기간/대상/접수) → DB 저장"""
    list_url = (
        "https://everlearning.sen.go.kr/ever/menu/10014/bbs/20001/bbsPostList.do"
        "?recordCountPerPage=10"
        "&searchOrganNm=%EB%A7%88%ED%8F%AC%ED%8F%89%EC%83%9D%ED%95%99%EC%8A%B5%EA%B4%80"
    )
    chrome_opts = Options()
    chrome_opts.add_argument("--headless")
    chrome_opts.add_argument("--no-sandbox")
    chrome_opts.add_argument("--disable-dev-shm-usage")
    list_driver = None
    try:
        # ==============================
        # 1단계: 목록 크롤링 (링크 수집)
        # ==============================
        list_driver = webdriver.Chrome(options=chrome_opts)
        list_driver.get(list_url)
        all_data = []

        for page in range(1, 6):
            WebDriverWait(list_driver, 15).until(
                EC.presence_of_all_elements_located((By.CSS_SELECTOR, "table tbody tr"))
            )
            time.sleep(1.5)
            rows = list_driver.find_elements(By.CSS_SELECTOR, "table tbody tr")

            for row in rows:
                cells = row.find_elements(By.TAG_NAME, "td")
                if len(cells) >= 5:
                    # 상세 링크 추출: onclick="javascript:fnDetail('1211969'); return false;"
                    detail_link = ""
                    try:
                        a_tag = cells[2].find_element(By.TAG_NAME, "a")
                        onclick = a_tag.get_attribute("onclick") or ""
                        # fnDetail('게시물ID') 패턴에서 ID 추출
                        match = re.search(r"fnDetail\(['\"](\d+)['\"]\)", onclick)
                        if match:
                            post_id = match.group(1)
                            detail_link = (
                                "https://everlearning.sen.go.kr/ever/menu/10014"
                                "/bbs/20001/bbsPostDetail.do"
                                f"?currentPageNo={page}&postIdx={post_id}"
                                "&searchCategory=&recordCountPerPage=10"
                                "&searchOrganNm=%EB%A7%88%ED%8F%AC%ED%8F%89%EC%83%9D%ED%95%99%EC%8A%B5%EA%B4%80"
                            )
                    except Exception:
                        pass

                    all_data.append({
                        "번호": cells[0].text.strip(),
                        "분류": cells[1].text.strip(),
                        "제목": cells[2].text.strip(),
                        "공지기관명": cells[3].text.strip(),
                        "등록일": cells[4].text.strip(),
                        "_detail_link": detail_link,
                    })

            if page < 5:
                try:
                    nxt = list_driver.find_element(
                        By.XPATH, f"//div[@class='paging']//a[text()='{page + 1}']"
                    )
                    list_driver.execute_script("arguments[0].click();", nxt)
                    time.sleep(2)
                except Exception:
                    break

        # 목록 드라이버 즉시 종료 (세션 충돌 방지)
        list_driver.quit()
        list_driver = None
        print(f"[에버러닝] 목록 {len(all_data)}건 수집 완료")

        # ==============================
        # 2단계: 기존 DB에서 이미 채워진 상세 정보 불러오기
        # ==============================
        existing_details = {}
        try:
            existing_df = pd.read_sql(
                text("SELECT 제목, 운영기간, 운영대상, 접수기간 FROM everlearning_mapo"),
                engine
            )
            for _, row in existing_df.iterrows():
                op = (row.get("운영기간") or "").strip()
                tg = (row.get("운영대상") or "").strip()
                ap = (row.get("접수기간") or "").strip()
                # 3개 모두 채워져 있어야 스킵 (하나라도 비면 재크롤링)
                if op and tg and ap:
                    existing_details[row["제목"]] = {
                        "운영기간": op, "운영대상": tg, "접수기간": ap,
                    }
            print(f"[에버러닝] 기존 DB에서 {len(existing_details)}건 상세 정보 로드 (실제 데이터 있는 건만)")
        except Exception:
            print("[에버러닝] 기존 테이블 없음, 전체 크롤링 진행")

        # ==============================
        # 3단계: 빈칸인 게시물만 상세 크롤링 (이미 있는 건 스킵)
        # ==============================
        crawl_count = 0
        skip_count = 0

        for item in all_data:
            title = item.get("제목", "")

            # 이미 DB에 상세 정보가 있으면 그대로 사용 (스킵)
            if title in existing_details:
                item["운영기간"] = existing_details[title]["운영기간"]
                item["운영대상"] = existing_details[title]["운영대상"]
                item["접수기간"] = existing_details[title]["접수기간"]
                skip_count += 1
            # 상세 정보 없음 → 크롤링
            elif item.get("_detail_link"):
                crawl_count += 1
                print(f"    [{crawl_count}] 상세 크롤링: {title[:30]}...")
                try:
                    detail_info = _extract_detail_with_gemini(item["_detail_link"])
                    item["운영기간"] = detail_info["운영기간"]
                    item["운영대상"] = detail_info["운영대상"]
                    item["접수기간"] = detail_info["접수기간"]
                except Exception as e:
                    print(f"    [실패] {title[:30]}: {e}")
                    item["운영기간"] = ""
                    item["운영대상"] = ""
                    item["접수기간"] = ""
                time.sleep(15)
            else:
                item["운영기간"] = ""
                item["운영대상"] = ""
                item["접수기간"] = ""

            item.pop("_detail_link", None)

        print(f"[에버러닝] 스킵 {skip_count}건, 신규 크롤링 {crawl_count}건")

        # ==============================
        # 4단계: DB 저장 (크롤링 성공/실패 관계없이 항상 저장)
        # ==============================
        if all_data:
            pd.DataFrame(all_data).to_sql(
                "everlearning_mapo", engine, if_exists="replace", index=False
            )
            print(f"[에버러닝] {len(all_data)}건 (상세 포함) 갱신 완료")
    except Exception as e:
        print(f"[에버러닝] 크롤링 오류: {e}")
    finally:
        if list_driver:
            list_driver.quit()



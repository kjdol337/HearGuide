# Whisper 환각 텍스트 패턴 (무음/잡음 시 자주 나오는 문구들)
WHISPER_HALLUCINATION_PATTERNS = [
    "시청해주셔서 감사합니다",
    "구독과 좋아요",
    "thank you for watching",
    "thanks for watching",
    "please subscribe",
    "MBC 뉴스",
    "KBS",
    "자막",
    "subtitle",
]

def record_and_transcribe(duration: int = 5) -> str:
    """마이크 녹음 → Whisper STT (무음/환각 필터 포함)"""
    asr = load_whisper()
    audio = sd.rec(int(duration * 16000), samplerate=16000, channels=1, dtype=np.int16)
    sd.wait()

    # ① 무음 체크: RMS(음량)가 너무 낮으면 빈 문자열 반환
    rms = np.sqrt(np.mean(audio.astype(np.float32) ** 2))
    if rms < 80:   # 경험치: 80~150 사이로 조정 가능
        return ""

    wav_path = "temp_question.wav"
    wavio.write(wav_path, audio, 16000, sampwidth=2)
    result = asr(wav_path, generate_kwargs={"language": "ko"})
    text = result["text"].strip()

    # ② 환각 텍스트 패턴 필터
    for pattern in WHISPER_HALLUCINATION_PATTERNS:
        if pattern.lower() in text.lower():
            return ""

    return text


def speak(text_msg: str) -> str:
    """TTS로 음성 파일 생성 후 경로 반환"""
    tts_path = "temp_answer.mp3"
    tts = gTTS(text=text_msg, lang="ko")
    tts.save(tts_path)
    return tts_path


